# Required: OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM model for difficulty generation
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Optional: override models for specific features
GALAXY_OPENROUTER_MODEL=google/gemini-2.0-flash-001
NARRATOR_OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Server config (defaults shown)
# PORT=3000
# GALAXY_ROTATION_HOURS=24

# Supabase (optional — enables persistent storage; falls back to filesystem without these)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-or-anon-key
